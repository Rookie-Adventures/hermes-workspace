{
    "window.commandCenter": true,
    "http.proxySupport": "off",
    "workbench.startupEditor": "welcomePageInEmptyWorkbench",
    "redhat.telemetry.enabled": false,
    "workbench.layoutControl.enabled": false,
    "window.autoDetectColorScheme": true,
    "chat.disableAIFeatures": true,
    "http.systemCertificatesNode": true,
    "geminicodeassist.project": "aiaiai-492209",
    "geminicodeassist.enableCodebaseIndexing": true,
    "geminicodeassist.codebaseIndexing.includePatterns": ["src/**/*.ts", "src/**/*.tsx", "gateway/**/*.py"],
    "geminicodeassist.experimental.codebaseAwareness": true,
    "terminal.integrated.defaultProfile.linux": "Google Cloud Shell",
    "window.menuBarVisibility": "classic",
    "google.cloud.project": "aiaiai-492209",
    "cloudShell.showCloudCodeInstallHint": false,
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": "always"
    },
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.expand": false,
    "explorer.fileNesting.patterns": {
        "package.json": "pnpm-lock.yaml, .npmrc, .prettierrc*, eslint.config.js, .prettierignore, .eslintignore",
        "tsconfig.json": "tsconfig.*.json",
        ".env": ".env.*, .env.example",
        "vite.config.ts": "vite.config.*, vitest.config.*",
        "Dockerfile": ".dockerignore, docker-compose*, docker"
    },
    "files.exclude": {
        "**/.git": true,
        "**/.DS_Store": true,
        "**/node_modules": true,
        "**/dist": true,
        "**/.vinxi": true
    },
    "search.exclude": {
        "**/node_modules": true,
        "**/dist": true,
        "**/pnpm-lock.yaml": true,
        "**/.vinxi": true
    },
    "typescript.updateImportsOnPaste": true,
    "javascript.updateImportsOnPaste": true,
    "editor.suggestOnTriggerCharacters": true,
    "editor.inlineSuggest.enabled": true,
    "terminal.integrated.fontSize": 14,
    "terminal.integrated.copyOnSelection": true,
    "terminal.integrated.scrollback": 10000,
    "git.autofetch": true,
    "git.enableSmartCommit": true,
    "git.confirmSync": false,
    "git.postCommitCommand": "push",
    "git.pullBeforePush": true
}
